# ============================================================================
# Aikya — environment configuration template
# Copy to `.env` and fill in real values. NEVER commit your real .env.
# ============================================================================

# ---- Core ----
NODE_ENV=production
PORT=3001

# ---- Frontend (build-time, must be prefixed VITE_) ----
VITE_API_URL=https://api.your-domain.com
VITE_GITHUB_CLIENT_ID=
VITE_BILLING_ENABLED=false

# ---- Auth / security ----
# Generate a strong 32+ char secret:  openssl rand -hex 32
JWT_SECRET=
# Comma-separated emails that get Aikya master-admin (platform) access.
PLATFORM_ADMIN_EMAILS=you@your-company.com
# Encryption key for stored integration credentials:  openssl rand -hex 32
INTEGRATION_MASTER_KEY=

# ---- Rate limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX=30

# ---- Database ----
# DB_DIALECT: sqlite (local + low-cost production) | mysql (scale-up production)
DB_DIALECT=sqlite
# SQLite file path. Locally a relative path is fine. On a container platform,
# point this at a PERSISTENT VOLUME (e.g. /data/devops_ai.sqlite on Railway),
# otherwise the database is wiped on every deploy/restart.
SQLITE_STORAGE=devops_ai.sqlite
# MySQL (used when DB_DIALECT=mysql). Either set MYSQL_URL or the discrete vars.
MYSQL_URL=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_SSL=false

# ---- URLs & CORS (OAuth auto-detects from the request; these are for CORS/invites) ----
APP_BASE_URL=https://app.your-domain.com
CORS_ORIGIN=https://app.your-domain.com
# Optional explicit override; leave blank to auto-derive from the request host.
INTEGRATION_OAUTH_REDIRECT_BASE=

# ---- Email (OTP, invites, notifications) ----
# Gmail: use an App Password. Or set EMAIL_HOST/PORT/SECURE for a custom SMTP.
EMAIL_SERVICE=gmail
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
BUSINESS_INBOX=

# ---- AI providers (bring-your-own-AI; leave blank until connected) ----
AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=google/flan-t5-base

# ---- Billing ----
BILLING_ENABLED=false
BILLING_CURRENCY=USD

# ---- Integration OAuth apps (register callbacks on each provider) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
INTEGRATION_GITHUB_CLIENT_ID=
INTEGRATION_GITHUB_CLIENT_SECRET=
INTEGRATION_GITLAB_CLIENT_ID=
INTEGRATION_GITLAB_CLIENT_SECRET=
INTEGRATION_SLACK_CLIENT_ID=
INTEGRATION_SLACK_CLIENT_SECRET=

# ---- Integration sync job ----
INTEGRATION_SYNC_ENABLED=true
INTEGRATION_SYNC_INTERVAL_MINUTES=10
INTEGRATION_SYNC_BATCH_LIMIT=25
INTEGRATION_SYNC_AUTO_ON_CONNECT=true

# ---- Cloud ----
AWS_REGION=us-east-1
