{
  "name": "ai-devops-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/pricing"
    ],
    "skipThirdPartyRequests": true,
    "inlineCss": false,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ]
  },
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "client": "vite",
    "server:dev": "nodemon --watch server server/index.js",
    "server": "node server/index.js",
    "ops:aidevops": "node services/ops-aidevops/index.js",
    "ops:business": "node services/ops-business/index.js",
    "ops:commerce": "node services/ops-commerce/index.js",
    "ops:finance": "node services/ops-finance/index.js",
    "ops:project": "node services/ops-project/index.js",
    "ops:marketing": "node services/ops-marketing/index.js",
    "ops:all": "concurrently \"npm run ops:aidevops\" \"npm run ops:business\" \"npm run ops:commerce\" \"npm run ops:finance\" \"npm run ops:project\" \"npm run ops:marketing\"",
    "build": "tsc -b && vite build",
    "build:seo": "npm run build && (react-snap || echo prerender skipped)",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js",
    "test": "jest",
    "test-deployment": "node scripts/test-deployment.js",
    "migrate": "node server/database/migrate.js",
    "reset:dev": "node scripts/reset-dev-data.js",
    "backup": "node scripts/backup.js",
    "security-check": "npm audit && snyk test"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.828.0",
    "@aws-sdk/client-rds": "^3.828.0",
    "@octokit/rest": "^22.0.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "imapflow": "^1.2.4",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.460.0",
    "mailparser": "^3.9.1",
    "mysql2": "^3.12.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.1.7",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "husky": "^9.0.10",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.49",
    "react-snap": "^1.23.0",
    "snyk": "^1.1280.0",
    "supertest": "^6.3.4",
    "tailwindcss": "^3.4.14",
    "terser": "^5.43.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
